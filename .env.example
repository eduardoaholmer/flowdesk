# Copie para ".env" (nunca commite o ".env" real — ver .gitignore) antes de rodar
# `docker compose up`. DATABASE_URL e REDIS_URL não precisam ser definidos aqui:
# o docker-compose.yml já os aponta para os serviços "postgres"/"redis" da rede
# interna do Compose. Estas variáveis são as que fazem sentido customizar por
# ambiente (dev local vs. CI vs. produção futura).

# --- Backend (ver backend/src/core/config.py) ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Frontend (ver frontend/src/vite-env.d.ts) ---
VITE_API_URL=http://localhost:8000/api/v1
