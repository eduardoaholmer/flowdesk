# Template de referência para `docker compose -f docker-compose.prod.yml --env-file
# .env.production up --build` (Sprint 17.4/M6, ADR-040). Copie para ".env.production"
# e preencha com segredos reais antes de usar — nunca commite o arquivo real (já
# coberto por .gitignore). Nenhum valor abaixo é utilizável como está: são
# placeholders para descoberta do conjunto completo de variáveis esperado, não
# segredos de exemplo prontos para copiar (diferente de `.env.example`, que usa um
# par de chaves JWT de DEV real e documentado como tal).
#
# Este arquivo é só o template do que o app espera via variável de ambiente — não
# substitui um gerenciador de segredos real (Vault, AWS Secrets Manager, GitHub
# Environments) em um pipeline de deploy de verdade (`PRODUCTION_CHECKLIST.md`).

# --- Ambiente (backend/src/core/config.py) ---
ENVIRONMENT=production
LOG_LEVEL=INFO
# Origem real do frontend em produção — nunca "*" combinado com credenciais
# (docs/07-security.md §5).
CORS_ORIGINS=https://app.example.com

# --- Postgres (usado tanto para interpolação em docker-compose.prod.yml
# quanto como parte de DATABASE_URL montada pelo próprio compose) ---
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=flowdesk

# --- JWT (RS256) — NUNCA reaproveitar o par de DEV de .env.example em produção
# (docs/09-decision-log.md ADR-008; Settings recusa subir se detectar isso).
# Gerar um par novo: `openssl genrsa -out private.pem 2048 && openssl rsa -in
# private.pem -pubout -out public.pem`, depois substituir quebras de linha reais
# por `\n` literal (o valor precisa caber em uma única linha de variável de
# ambiente) e colar abaixo.
JWT_PRIVATE_KEY=CHANGE_ME
JWT_PUBLIC_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
INVITATION_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- Storage de anexos (core/storage.py, Sprint 17.2/M6, ADR-038) — "local"
# funciona só para instância única; um deploy com múltiplas réplicas exige "s3".
# Credenciais nunca vão aqui: use as variáveis padrão do boto3
# (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY) ou um IAM role.
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# S3_BUCKET_NAME=CHANGE_ME
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=  # só para S3-compatible não-AWS (MinIO/R2/Spaces)

# --- E-mail transacional (core/mail.py, Sprint 17.3/M6, ADR-039) — "logging"
# nunca envia e-mail real; recuperação de senha em produção exige "smtp".
MAIL_PROVIDER=logging
# MAIL_PROVIDER=smtp
# SMTP_HOST=CHANGE_ME
# SMTP_PORT=587
# SMTP_USERNAME=CHANGE_ME
# SMTP_PASSWORD=CHANGE_ME
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_USE_TLS=true
FRONTEND_BASE_URL=https://app.example.com

# --- Frontend (build-arg do docker/frontend.Dockerfile, ver frontend/src/vite-env.d.ts) ---
VITE_API_URL=https://api.example.com/api/v1
