# Anexos (Sprint 8) — valores abaixo já são o default de core/config.py; listados
# aqui só para descoberta (ver docs/06-backend.md §10 para a referência completa de
# variáveis). Descomentar e ajustar apenas se precisar de um valor diferente do default.
# UPLOAD_DIR=var/uploads
# MAX_UPLOAD_SIZE_BYTES=10485760
# ALLOWED_UPLOAD_CONTENT_TYPES=image/png,image/jpeg,image/gif,image/webp,image/svg+xml,application/pdf,text/plain,text/csv,application/zip,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Storage S3-compatible (Sprint 17.2/M6, ADR-038) — alternativa a armazenar anexos
# em disco local. Credenciais NUNCA vão aqui: use as variáveis padrão do boto3
# (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY) ou um IAM role.
# STORAGE_PROVIDER=s3
# S3_BUCKET_NAME=flowdesk-attachments
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=http://localhost:9000  # só para S3-compatible não-AWS (MinIO/R2/Spaces)

# E-mail transacional via SMTP real (Sprint 17.3/M6, ADR-039) — alternativa ao
# placeholder de log (default). FRONTEND_BASE_URL monta o link de reset
# ({FRONTEND_BASE_URL}/reset-password/{token}) mesmo com MAIL_PROVIDER=logging.
# MAIL_PROVIDER=smtp
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@flowdesk.example
# SMTP_USE_TLS=true
# FRONTEND_BASE_URL=http://localhost:5173
