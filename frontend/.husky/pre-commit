#!/usr/bin/env sh

cd frontend && npx lint-staged
cd ..

if [ -x backend/.venv/Scripts/pre-commit ] || [ -x backend/.venv/bin/pre-commit ]; then
  . backend/.venv/Scripts/activate 2>/dev/null || . backend/.venv/bin/activate
  pre-commit run
else
  echo "pre-commit não encontrado em backend/.venv — pulando hooks de backend (ver README)."
fi
